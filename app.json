{
  "expo": {
    "name": "SAFAAR",
    "slug": "safaar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "safaar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.safaar.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "SAFAAR needs camera access to take photos for posts and experiences.",
        "NSPhotoLibraryUsageDescription": "SAFAAR needs photo library access to share photos in posts and experiences.",
        "NSLocationWhenInUseUsageDescription": "SAFAAR uses your location to find experiences and travelers near you.",
        "NSMicrophoneUsageDescription": "SAFAAR needs microphone access for voice messages."
      }
    },
    "android": {
      "package": "app.safaar.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF8F4"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-location",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C4993C"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
